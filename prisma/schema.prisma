generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TYPY DOKUMENTÓW
// ============================================================

enum DocumentDirection {
  RECEIVABLE // należność — do otrzymania (np. faktura sprzedażowa)
  PAYABLE    // zobowiązanie — do zapłaty (np. faktura kosztowa)
}

model DocumentType {
  id        String             @id @default(cuid())
  name      String             @unique
  direction DocumentDirection
  isSystem  Boolean            @default(false)
  documents Document[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

// ============================================================
// KONTRAHENCI
// ============================================================

model Contractor {
  id                String     @id @default(cuid())
  name              String
  nip               String     @unique
  address           String?
  bankAccountNumber String?
  defaultCategoryId String?
  defaultCategory   Category?  @relation(fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  documents         Document[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([nip])
}

// ============================================================
// KATEGORIE (drzewo — self-referencing)
// ============================================================

model Category {
  id          String       @id @default(cuid())
  name        String
  parentId    String?
  parent      Category?    @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children             Category[]           @relation("CategoryTree")
  contractors          Contractor[]
  documents            Document[]
  categorizationRules  CategorizationRule[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([parentId])
}

// ============================================================
// DOKUMENTY (faktury)
// ============================================================

enum DocumentStatus {
  BUFFER   // w buforze — czeka na akceptację
  ACCEPTED // zaakceptowany — w rejestrze
}

enum DocumentSource {
  KSEF   // pobrane z KSeF
  UPLOAD // wgrane przez upload
  MANUAL // dodane ręcznie
}

model Document {
  id                String         @id @default(cuid())
  invoiceNumber     String
  documentTypeId    String
  documentType      DocumentType   @relation(fields: [documentTypeId], references: [id])
  contractorId      String
  contractor        Contractor     @relation(fields: [contractorId], references: [id])
  issueDate         DateTime       @db.Date
  dueDate           DateTime       @db.Date
  amountNet         Decimal        @db.Decimal(12, 2)
  amountVat         Decimal        @db.Decimal(12, 2)
  amountGross       Decimal        @db.Decimal(12, 2)
  bankAccountNumber String?
  categoryId        String?
  category          Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  source            DocumentSource
  // Stabilny klucz idempotentności dla dokumentów importowanych z KSeF.
  ksefNumber        String?        @unique
  status            DocumentStatus @default(BUFFER)
  fileName          String?
  filePath          String?
  fileType          String?
  xmlData           Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([invoiceNumber, contractorId], name: "unique_invoice")
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
  @@index([documentTypeId])
  @@index([contractorId])
  @@index([categoryId])
  @@index([source])
}

// ============================================================
// HARMONOGRAM KSeF
// ============================================================

model KSeFSchedule {
  id        String    @id @default(cuid())
  hour      Int       // 0-23
  minute    Int       @default(0) // 0-59
  isActive  Boolean   @default(true)
  fetchType String    @default("BOTH") // COST / SALES / BOTH
  lastRunAt DateTime?
  lastError String?
  lastErrorAt DateTime?
  lockToken String?
  lockedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, hour, minute])
}

// ============================================================
// REGUŁY AUTO-KATEGORYZACJI (bonus)
// ============================================================

model CategorizationRule {
  id         String   @id @default(cuid())
  pattern    String
  matchField String   // "contractorName" | "invoiceNumber" | "description"
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  priority   Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================
// KONFIGURACJA KOLUMN
// ============================================================

model ColumnConfig {
  id        String  @id @default(cuid())
  columnKey String  @unique
  isVisible Boolean @default(true)
  position  Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
